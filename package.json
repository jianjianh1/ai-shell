{
  "name": "ai-shell",
  "description": "A CLI that converts natural language to shell commands.",
  "version": "1.0.12",
  "type": "module",
  "dependencies": {
    "clipboardy": "^2.3.0",
    "execa": "^7.1.1"
  },
  "bin": {
    "ai-shell": "./dist/cli.mjs",
    "ai": "./dist/cli.mjs"
  },
  "scripts": {
    "start": "jiti ./src/cli.ts",
    "typecheck": "tsc",
    "build": "pkgroll",
    "compile": "pkgroll && bun build dist/cli.mjs --compile --outfile ai-bin"
  },
  "devDependencies": {
    "@clack/core": "latest",
    "@clack/prompts": "latest",
    "@types/node": "^18.15.11",
    "cleye": "^1.3.2",
    "jiti": "^1.17.0",
    "pkgroll": "^1.9.0",
    "typescript": "^4.9.5"
  }
}
